# ── Retell AI ─────────────────────────────────────────────────────────────────
RETELL_API_KEY=your_retell_api_key_here
RETELL_AGENT_ID=
RETELL_AGENT_ID_INBOUND=your_retell_inbound_agent_id_here
RETELL_AGENT_ID_OUTBOUND=your_retell_outbound_agent_id_here
RETELL_FROM_NUMBER=+18002225345

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
BACKFILL_PHONE_NUMBER=+18002225345

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=backfill.db
# Expose locally with: ngrok http 8000
BACKFILL_WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# ── 7shifts (Phase 1 — Track B) ──────────────────────────────────────────────
SEVENSHIFTS_CLIENT_ID=your_7shifts_client_id_here
SEVENSHIFTS_CLIENT_SECRET=your_7shifts_client_secret_here
SEVENSHIFTS_WEBHOOK_SECRET=

# ── Deputy (Phase 1 — Track C) ────────────────────────────────────────────────
DEPUTY_CLIENT_ID=your_deputy_client_id_here
DEPUTY_CLIENT_SECRET=your_deputy_client_secret_here
DEPUTY_WEBHOOK_SECRET=

# ── When I Work (Phase 1 — Track D) ──────────────────────────────────────────
WHENIWORK_DEVELOPER_KEY=your_wheniwork_developer_key_here
WHENIWORK_WEBHOOK_SECRET=

# ── Homebase (Phase 1 — read-only companion) ──────────────────────────────────
HOMEBASE_API_KEY=your_homebase_api_key_here
