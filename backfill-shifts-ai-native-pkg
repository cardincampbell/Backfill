```json
{
  "action_request_id": 501,
  "status": "awaiting_confirmation",
  "mode": "confirmation",
  "summary": "I found Randy Lopez on Friday's closing shift and can remove him and open coverage.",
  "risk_class": "yellow",
  "requires_confirmation": true,
  "confirmation": {
